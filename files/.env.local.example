# .env.local — fill in real values
# ────────────────────────────────────────────────────
# ETL (Python script): connects to SYS, writes SQLite
# Dashboard (Next.js): reads SQLite — never touches SYS
# ────────────────────────────────────────────────────

# === SYS MS SQL Server credentials (ETL only) ===
SQL_SERVER=your-sys-server.example.com
SQL_PORT=1433
SQL_DATABASE=SysPurchaseDB
SQL_USER=readonly_user
SQL_PASSWORD=changeme
SQL_ENCRYPT=false
SQL_TRUST_CERT=true

# === Table & columns (ETL only) ===
SQL_TABLE=SysPurchaseDB.dbo.CapexProjects
SQL_COL_STATUS=status
SQL_COL_BUDGET=budget_amount
SQL_COL_ACTUAL=actual_amount
SQL_COL_COMMITTED=committed_amount
SQL_COL_DATE=project_date

# === Divisor: 1000000 if raw Baht, 1 if already in millions ===
SQL_MB_DIVISOR=1000000

# === SQLite path (dashboard reads this) ===
SQLITE_PATH=./data/dashboard.db
